# =============================================================================
# Agentic Project Service Environment Configuration
# =============================================================================
# This service runs INSIDE each project's Supabase stack.
# These variables are typically set by the project's docker-compose.yml
# and passed from the project's .env file.
#
# For local development, copy this file to .env:
#   cp env.example .env

############
# Database Connection (Project's PostgreSQL)
############
# Each project has its own PostgreSQL database
DATABASE_URL=postgresql+psycopg://postgres:your-project-password@localhost:5432/postgres

############
# Redis (Celery Message Broker)
############
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

############
# JWT Authentication
############
# Must match the project's Supabase JWT_SECRET
JWT_SECRET=your-project-jwt-secret

############
# AI Configuration
############
# Required for embeddings and LLM features
OPENAI_API_KEY=sk-...

# Optional: Use LiteLLM for multi-provider support
# ANTHROPIC_API_KEY=sk-ant-...
# LITELLM_MODEL=gpt-4o-mini

############
# Supabase Storage (for file uploads)
############
# The project's internal Supabase URL
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_KEY=your-project-service-role-key

############
# Flask Configuration
############
FLASK_ENV=development
FLASK_DEBUG=1
